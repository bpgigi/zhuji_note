<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ZhujiNote" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.ZhujiNote.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FAF9F5</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.ZhujiNote</item>
    </style>

    <color name="claude_canvas">#FAF9F5</color>
    <color name="claude_ink">#141413</color>
    <color name="claude_coral">#CC785C</color>
    <color name="windsurf_neon">#34E8BB</color>
    <color name="windsurf_charcoal">#0B100F</color>
</resources>
